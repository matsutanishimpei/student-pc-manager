<Window x:Class="client.ProcessViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロセス詳細・画面キャプチャ監視" Height="550" Width="1100"
        Background="#18181B" FontFamily="Segoe UI, Yu Gothic" TextElement.Foreground="#F4F4F5"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Button Styles -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3F3F46"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#52525B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListView Styles -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#1E1E21"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E4E4E7"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <GridViewRowPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter Property="Background" Value="#27272A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="true">
                    <Setter Property="Background" Value="#312E81"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Panel -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="対象PC: " FontSize="16" FontWeight="Bold" Foreground="#A1A1AA"/>
                <TextBlock x:Name="TargetPcTextBlock" Text="Loading..." FontSize="16" FontWeight="Bold" Foreground="#F4F4F5"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="除外設定..." Style="{StaticResource SecondaryButton}" Click="EditExclusionsButton_Click" Margin="0,0,8,0"/>
                <Button Content="プロセス更新" Click="RefreshButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Split Grid for processes and screenshot -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Process ListView -->
            <ListView x:Name="ProcessListView" Grid.Column="0">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="このプロセス名を除外リストに追加" Click="ExcludeProcessMenuItem_Click"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="80"/>
                        <GridViewColumn Header="プロセス名" DisplayMemberBinding="{Binding ProcessName}" Width="150"/>
                        <GridViewColumn Header="ウィンドウタイトル" DisplayMemberBinding="{Binding MainWindowTitle}" Width="280"/>
                        <GridViewColumn Header="操作" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="強制終了" Background="#EF4444" FontSize="11" Padding="6,2" Click="KillProcessButton_Click" Tag="{Binding Id}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#27272A" Margin="4,0"/>

            <!-- RIGHT: Screen Capture Viewer -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Screenshot Image -->
                <Border Grid.Row="0" Background="#121214" BorderBrush="#27272A" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <!-- Image Viewer -->
                        <Image x:Name="ScreenshotImage" Stretch="Uniform" Margin="5"/>
                        <!-- Center status placeholder -->
                        <TextBlock x:Name="ImageStatusTextBlock" Text="キャプチャ未取得" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#71717A" FontSize="14"/>
                    </Grid>
                </Border>

                <!-- Screenshot Actions -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="画面キャプチャ取得" Click="CaptureButton_Click"/>
                    <Button Grid.Column="2" Content="保存..." Style="{StaticResource SecondaryButton}" Click="SaveImageButton_Click" x:Name="SaveImageButton" IsEnabled="False"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="2" Text="読み込み中..." Foreground="#A1A1AA" FontSize="12"/>
    </Grid>
</Window>
