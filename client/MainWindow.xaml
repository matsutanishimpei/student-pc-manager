<Window x:Class="client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:client"
        mc:Ignorable="d"
        Title="sendCMD - 実習室管理コンソール" Height="650" Width="1000"
        Background="#18181B" FontFamily="Segoe UI, Yu Gothic" TextElement.Foreground="#F4F4F5">
    
    <Window.Resources>
        <!-- Custom button style with rounded corners -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3F3F46"/>
                    <Setter Property="Foreground" Value="#A1A1AA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3F3F46"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#52525B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Textbox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#F4F4F5"/>
            <Setter Property="SelectionBrush" Value="#6366F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E21"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" ContentSource="Header" Focusable="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1E21"/>
                                <Setter Property="Foreground" Value="#F4F4F5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: PC LIST -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- TabControl (Add Methods) -->
                <RowDefinition Height="Auto"/> <!-- List Actions Toolbar -->
                <RowDefinition Height="*"/>    <!-- PC ListBox -->
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="ターゲットPC一覧" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#F4F4F5"/>

            <!-- Add PC Methods TabControl -->
            <TabControl Grid.Row="1" Margin="0,0,0,10">
                <!-- Tab 1: Manual Add -->
                <TabItem Header="手動追加">
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewPcTextBox" Grid.Column="0" Margin="0,0,8,0" Padding="8,4" VerticalAlignment="Center" Text="127.0.0.1:5000"/>
                        <Button Grid.Column="1" Content="追加" Click="AddPcButton_Click" Padding="12,6"/>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Bulk Generate -->
                <TabItem Header="一括生成">
                    <StackPanel Margin="0,5">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="接頭辞 (例: PC-ST-):" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,3"/>
                                <TextBox x:Name="PrefixTextBox" Text="PC-STUDENT-" Padding="6,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ポート:" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,3"/>
                                <TextBox x:Name="PortTextBox" Text="5000" Padding="6,3"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="開始" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,3"/>
                                <TextBox x:Name="StartNumTextBox" Text="1" Padding="6,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="終了" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,3"/>
                                <TextBox x:Name="EndNumTextBox" Text="40" Padding="6,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="桁数" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,3"/>
                                <TextBox x:Name="DigitsTextBox" Text="2" Padding="6,3"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="一括生成" Click="BulkGenerateButton_Click" HorizontalAlignment="Right" Padding="12,6"/>
                    </StackPanel>
                </TabItem>

                <!-- Tab 3: IP Scan -->
                <TabItem Header="IPスキャン">
                    <StackPanel Margin="0,5" VerticalAlignment="Center">
                        <TextBlock Text="指定したIPアドレス範囲をスキャンし生存PCを自動追加します。" Foreground="#A1A1AA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="IP範囲スキャンを開始..." Click="IpScanButton_Click" HorizontalAlignment="Stretch" Padding="0,10"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- List Actions Toolbar -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="全選択" Click="SelectAllButton_Click" Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11"/>
                <Button Grid.Column="2" Content="全解除" Click="DeselectAllButton_Click" Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11"/>
                <Button Grid.Column="4" Content="選択削除" Click="DeleteSelectedButton_Click" Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Foreground="#EF4444"/>
            </Grid>

            <!-- PC ListBox -->
            <ListBox x:Name="PcListBox" Grid.Row="3" Background="#1E1E21" BorderBrush="#27272A" BorderThickness="1" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionMode="Multiple" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}" 
                                  Foreground="#E4E4E7" Margin="5" VerticalAlignment="Center"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#27272A" Margin="10,0"/>

        <!-- RIGHT PANEL: ACTIONS & LOGS -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Global Settings (API Key) -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API認証キー:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <TextBox x:Name="ApiKeyTextBox" Grid.Column="1" Text="5c3e7f41-0f73-455b-b9d9-482470724653"/>
            </Grid>

            <!-- Action Tabs -->
            <TabControl Grid.Row="1" Background="#1E1E21" BorderBrush="#27272A" BorderThickness="1" Margin="0,0,0,15">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Header" Value="{Binding Header}"/>
                        <Setter Property="Background" Value="#27272A"/>
                        <Setter Property="Foreground" Value="#D4D4D8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#4F46E5"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- TAB 1: POWERSHELL -->
                <TabItem Header="PowerShell 実行">
                    <Border Padding="15" Background="#1E1E21">
                        <StackPanel>
                            <TextBlock Text="実行するコマンドを入力してください" Margin="0,0,0,8" Foreground="#A1A1AA"/>
                            <TextBox x:Name="CommandTextBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                                     FontFamily="Consolas" FontSize="13" VerticalScrollBarVisibility="Auto" AcceptsTab="True"
                                     Text="Get-Process | Where-Object { $_.MainWindowTitle } | Select-Object ProcessName, Id, MainWindowTitle"/>
                            <Button Content="選択されたPCで実行" Click="ExecuteCommandButton_Click" Margin="0,12,0,0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- TAB 2: FILE DISTRIBUTION -->
                <TabItem Header="ファイル配布とインストール">
                    <Border Padding="15" Background="#1E1E21">
                        <StackPanel>
                            <TextBlock Text="配布するファイル（インストーラーなど）を選択してください" Margin="0,0,0,8" Foreground="#A1A1AA"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FilePathTextBox" Grid.Column="0" IsReadOnly="True" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="参照..." Style="{StaticResource SecondaryButton}" Click="BrowseFileButton_Click" Padding="12,6"/>
                            </Grid>

                            <CheckBox x:Name="ExecuteAfterUploadCheckBox" Content="アップロード後にこのファイルを実行する" 
                                      IsChecked="True" Foreground="#D4D4D8" Margin="0,5,0,10"/>

                            <TextBlock Text="実行時引数 (例: サイレントインストールの引数 /qn など):" Margin="0,0,0,5" Foreground="#A1A1AA"/>
                            <TextBox x:Name="ExecutionArgsTextBox" Text="/qn" Margin="0,0,0,12"/>

                            <Button Content="ファイルを配布してインストール" Click="DistributeFileButton_Click" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- TAB 3: MONITOR & MANAGEMENT -->
                <TabItem Header="稼働監視 (リアルタイム)">
                    <Border Padding="15" Background="#1E1E21">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="選択されたPCのアクティブアプリ一覧を表示します（ダブルクリックで詳細表示）。" VerticalAlignment="Center" Foreground="#A1A1AA" FontSize="11"/>
                                <Button Grid.Column="1" Content="一斉取得" Click="GetActiveAppsButton_Click" Padding="12,6"/>
                            </Grid>
                            
                            <ListView x:Name="MonitorListView" Grid.Row="1" Background="#121214" BorderBrush="#27272A" Foreground="#E4E4E7" MouseDoubleClick="MonitorListView_MouseDoubleClick">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="PCアドレス/ホスト名" DisplayMemberBinding="{Binding PcAddress}" Width="160"/>
                                        <GridViewColumn Header="ステータス" Width="100">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="アクティブアプリ" DisplayMemberBinding="{Binding ActiveApp}" Width="300"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Logs Section Title -->
            <TextBlock Grid.Row="3" Text="実行ログ・ステータス" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

            <!-- Logs Text Box -->
            <TextBox x:Name="LogTextBox" Grid.Row="4" Background="#121214" Foreground="#10B981" BorderBrush="#27272A" 
                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                     FontFamily="Consolas" FontSize="12" Padding="10"/>
        </Grid>
    </Grid>
</Window>
