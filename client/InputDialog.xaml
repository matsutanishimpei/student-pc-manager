<Window x:Class="client.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学生名の設定" Height="180" Width="380"
        Background="#1E1E21" FontFamily="Segoe UI, Yu Gothic" TextElement.Foreground="#F4F4F5"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptLabel" Text="学生名を入力してください:" FontSize="13" Margin="0,0,0,10"/>
        
        <TextBox Grid.Row="1" x:Name="InputTextBox" VerticalAlignment="Center" 
                 Background="#27272A" Foreground="#F4F4F5" BorderBrush="#3F3F46" BorderThickness="1" 
                 Padding="8,6" CaretBrush="#F4F4F5" SelectionBrush="#6366F1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="キャンセル" Click="CancelButton_Click" Width="80" Height="28" Margin="0,0,8,0"
                    Background="#3F3F46" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="決定" Click="OkButton_Click" IsDefault="True" Width="80" Height="28"
                    Background="#4F46E5" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
