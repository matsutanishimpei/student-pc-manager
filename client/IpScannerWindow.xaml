<Window x:Class="client.IpScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="IPアドレス範囲スキャン" Height="500" Width="650"
        Background="#18181B" FontFamily="Segoe UI, Yu Gothic" TextElement.Foreground="#F4F4F5"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3F3F46"/>
                    <Setter Property="Foreground" Value="#A1A1AA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3F3F46"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#52525B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CaretBrush" Value="#F4F4F5"/>
            <Setter Property="SelectionBrush" Value="#6366F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Settings -->
            <RowDefinition Height="Auto"/> <!-- Progress / Scan controls -->
            <RowDefinition Height="*"/>    <!-- Results List -->
            <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
        </Grid.RowDefinitions>

        <!-- Row 0: Scan Settings -->
        <Border Background="#1E1E21" BorderBrush="#27272A" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: Start IP -->
                <StackPanel Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="開始IPアドレス:" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox x:Name="StartIpTextBox" Text="192.168.1.1"/>
                </StackPanel>

                <!-- Col 1: End IP -->
                <StackPanel Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="終了IPアドレス:" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox x:Name="EndIpTextBox" Text="192.168.1.50"/>
                </StackPanel>

                <!-- Col 2: Port -->
                <StackPanel Grid.Column="2" Margin="0,0,0,8">
                    <TextBlock Text="ポート:" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox x:Name="PortTextBox" Text="5000"/>
                </StackPanel>

                <!-- Row 1: Registration Mode -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="登録形式:" Foreground="#A1A1AA" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RegByNameRadio" Content="PC名で登録 (推奨/DHCP向け)" IsChecked="True" Foreground="#F4F4F5" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <RadioButton x:Name="RegByIpRadio" Content="IPアドレスで登録 (固定IP向け)" Foreground="#F4F4F5" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Progress & Scan Button -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <ProgressBar x:Name="ScanProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Background="#27272A" Foreground="#6366F1" BorderThickness="0"/>
                <TextBlock x:Name="ProgressTextBlock" Text="開始ボタンを押すとスキャンを開始します。" FontSize="11" Foreground="#A1A1AA" Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="StartScanButton" Grid.Column="1" Content="スキャン開始" Click="StartScanButton_Click" Width="100"/>
            <Button x:Name="StopScanButton" Grid.Column="3" Content="停止" Click="StopScanButton_Click" Width="80" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
        </Grid>

        <!-- Row 2: Scan Results -->
        <ListView x:Name="ResultsListView" Grid.Row="2" Background="#121214" BorderBrush="#27272A" Foreground="#E4E4E7" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="IPアドレス" DisplayMemberBinding="{Binding IpAddress}" Width="150"/>
                    <GridViewColumn Header="検出PC名" DisplayMemberBinding="{Binding MachineName}" Width="180"/>
                    <GridViewColumn Header="ステータス" DisplayMemberBinding="{Binding Status}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Row 3: Bottom Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Selection helpers -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="全選択" Click="SelectAllButton_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="全解除" Click="DeselectAllButton_Click" Style="{StaticResource SecondaryButton}" Padding="10,6"/>
            </StackPanel>

            <Button x:Name="RegisterButton" Grid.Column="2" Content="選択したPCを追加" Click="RegisterButton_Click" Width="150"/>
            <Button Grid.Column="4" Content="キャンセル" Click="CancelButton_Click" Style="{StaticResource SecondaryButton}" Width="100"/>
        </Grid>
    </Grid>
</Window>
