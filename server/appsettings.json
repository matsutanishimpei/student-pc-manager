{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiKey": "",
  "ProtectedApiKey": "",
  "MinimumApiKeyLength": 16,
  "UploadDirectory": "C:\\Users\\Public\\sendCMD_uploads",
